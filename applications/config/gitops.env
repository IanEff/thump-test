# Cluster-scoped configuration injected into every infrastructure Application
# via the `../../config` Kustomize Component.
#
# Kustomize replacements use these values to patch hostnames, IPs, and CIDR
# references across all infrastructure manifests.
#
# CONTROL_PLANE_IP is the control-plane's INTERNAL static IP (the VPC-routable
# address other nodes use to reach the k3s API server — google_compute_address
# .control_plane_internal in network.tf). It's a literal placeholder here,
# substituted by control-plane.sh's startup script at boot (same convention as
# GITOPS_REPO_URL below), since the real value is only known once Tofu
# reserves that address. Never commit a substituted value.
#
# There is no separate GATEWAY_IP here (unlike ceph-lab): Cilium's
# L2Announcement/CiliumLoadBalancerIPPool mechanism (used on ceph-lab's Lima
# host-only L2 segment) doesn't work on GCP's routed VPC (no ARP broadcast
# domain), so the Gateway runs in `gatewayAPI.hostNetwork` mode instead,
# binding Envoy directly to whatever node it's pinned to (the control-plane
# node — see cilium/values.yaml's nodeLabelSelector). External DNS-facing
# access goes through the control-plane's EXTERNAL static IP instead, which
# isn't a cluster-config value at all — it's produced by `tofu output
# control_plane_external_ip` and consumed directly by
# provisioning/scripts/manage_hosts.py and fetch_kubeconfig.py on the Mac
# side, not by anything inside the cluster.
CONTROL_PLANE_IP=10.10.0.2

POD_CIDR=10.244.0.0/16
SERVICE_CIDR=10.96.0.0/12
DOMAIN=thump-test.lab
WILDCARD_DOMAIN=*.thump-test.lab

# Service hostnames
ARGOCD_HOSTNAME=argocd.thump-test.lab
GRAFANA_HOSTNAME=grafana.thump-test.lab
HUBBLE_HOSTNAME=hubble.thump-test.lab
DASHBOARD_HOSTNAME=dashboard.thump-test.lab
PROMETHEUS_HOSTNAME=prometheus.thump-test.lab

# Component versions — must match the vendored chart directories under
# applications/infrastructure/*/charts/
KUBERNETES_VERSION=1.33
GATEWAY_API_VERSION=v1.5.1
CILIUM_VERSION=1.19.3
ROOK_VERSION=v1.19.4
GRAFANA_VERSION=10.5.15
PROMETHEUS_VERSION=29.2.1
PROMETHEUS_OPERATOR_CRDS_VERSION=28.0.1
